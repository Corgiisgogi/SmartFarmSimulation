<Window x:Class="SmartFarmUI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:SmartFarmUI.Views.Converters"
        Title="스마트팜 모니터링 시스템" Height="768" Width="1280"
        Background="#1E1E2E" Foreground="White"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <conv:BoolToBrushConverter x:Key="BoolToBrushConverter"/>
        <conv:IntEqualConverter x:Key="IntEqualConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>

        <Style x:Key="SidebarBtn" TargetType="Button">
            <Setter Property="Background" Value="#2D2D44"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Margin" Value="4,2"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style x:Key="GroupBoxStyle" TargetType="GroupBox">
            <Setter Property="Foreground" Value="#4CAF50"/>
            <Setter Property="BorderBrush" Value="#444"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="6,4"/>
        </Style>
        <Style x:Key="LampBtn" TargetType="ToggleButton">
            <Setter Property="Background" Value="#2D2D44"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="Width" Value="80"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="#FFD700"/>
                    <Setter Property="Foreground" Value="#1E1E2E"/>
                    <Setter Property="BorderBrush" Value="#FFA000"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="FarmBtn" TargetType="Button">
            <Setter Property="Background" Value="#2D2D44"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Status Bar -->
        <StatusBar DockPanel.Dock="Bottom" Background="#12121F" Foreground="Gray">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}" Foreground="#4CAF50"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="PLC: " Foreground="Gray"/>
                    <TextBlock Text="{Binding AdsConnected}"
                               Foreground="{Binding AdsConnected, Converter={StaticResource BoolToBrushConverter}}"/>
                </StackPanel>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Flask: " Foreground="Gray"/>
                    <TextBlock Text="{Binding FlaskConnected}"
                               Foreground="{Binding FlaskConnected, Converter={StaticResource BoolToBrushConverter}}"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>

        <!-- Main 3-column layout -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="210"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT SIDEBAR -->
            <StackPanel Grid.Column="0" Background="#12121F">
                <!-- Power Control -->
                <GroupBox Header="전원 제어" Style="{StaticResource GroupBoxStyle}">
                    <StackPanel>
                        <Button Content="전원 ON" Command="{Binding PowerOnCommand}" Style="{StaticResource SidebarBtn}"/>
                        <Button Content="전원 OFF" Command="{Binding PowerOffCommand}" Style="{StaticResource SidebarBtn}"/>
                        <Separator Margin="0,4" Background="#333"/>
                        <Button Content="PLC 연결" Command="{Binding ConnectPlcCommand}" Style="{StaticResource SidebarBtn}"/>
                        <Button Content="PLC 해제" Command="{Binding DisconnectPlcCommand}" Style="{StaticResource SidebarBtn}"/>
                    </StackPanel>
                </GroupBox>

                <!-- Farm Selection -->
                <GroupBox Header="스마트팜 선택" Style="{StaticResource GroupBoxStyle}">
                    <StackPanel>
                        <Button Content="팜 1" Command="{Binding SelectFarmCommand}" CommandParameter="1"
                                Style="{StaticResource FarmBtn}">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentFarmId, Converter={StaticResource IntEqualConverter}, ConverterParameter=1}" Value="True">
                                            <Setter Property="Background" Value="#4CAF50"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Resources>
                        </Button>
                        <Button Content="팜 2" Command="{Binding SelectFarmCommand}" CommandParameter="2" Style="{StaticResource FarmBtn}"/>
                        <Button Content="팜 3" Command="{Binding SelectFarmCommand}" CommandParameter="3" Style="{StaticResource FarmBtn}"/>
                    </StackPanel>
                </GroupBox>

                <!-- Flask Connection -->
                <GroupBox Header="웹 서버" Style="{StaticResource GroupBoxStyle}">
                    <Button Content="Flask 연결" Command="{Binding ConnectFlaskCommand}" Style="{StaticResource SidebarBtn}"/>
                </GroupBox>

                <!-- Auto Control -->
                <GroupBox Header="자동 제어" Style="{StaticResource GroupBoxStyle}">
                    <StackPanel>
                        <CheckBox Content="자동 제어" IsChecked="{Binding AutoControlEnabled}"
                                  Foreground="White" Margin="4,2"/>
                        <CheckBox Content="AI 자동제어" IsChecked="{Binding AiAutoControlEnabled}"
                                  IsEnabled="{Binding FlaskConnected}"
                                  Foreground="White" Margin="4,2"/>
                    </StackPanel>
                </GroupBox>

                <Button Content="전체 로그 보기" Command="{Binding OpenLogViewCommand}"
                        Style="{StaticResource SidebarBtn}" Margin="4,8,4,4"/>
            </StackPanel>

            <!-- CENTER: Sensor Panels (2x2) -->
            <ScrollViewer Grid.Column="1" Background="#1E1E2E" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="8">
                    <TextBlock Text="센서 모니터링" FontSize="18" FontWeight="Bold"
                               Foreground="#4CAF50" Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Humidity -->
                        <Border Grid.Row="0" Grid.Column="0" Background="#2D2D44" Margin="4" Padding="12" CornerRadius="4">
                            <StackPanel>
                                <TextBlock Text="💧 습도" Foreground="#4CAF50" FontWeight="Bold"/>
                                <TextBlock FontSize="28" FontWeight="Bold" Foreground="White"
                                           Text="{Binding CurrentSensorData.Humidity, StringFormat={}{0:F1}%}"/>
                                <ProgressBar Value="{Binding CurrentSensorData.Humidity}" Maximum="100" Minimum="0"
                                             Height="8" Margin="0,4" Foreground="#4CAF50" Background="#444"/>
                                <DockPanel Margin="0,4,0,0">
                                    <TextBlock Text="최소" Foreground="Gray" Width="28" DockPanel.Dock="Left" FontSize="11" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding CurrentFarm.Thresholds[1].Min}" Foreground="White" Width="32"
                                               DockPanel.Dock="Right" TextAlignment="Right" FontSize="11" VerticalAlignment="Center"/>
                                    <Slider Value="{Binding CurrentFarm.Thresholds[1].Min, Mode=TwoWay}"
                                            Minimum="0" Maximum="100" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                                </DockPanel>
                                <DockPanel>
                                    <TextBlock Text="최대" Foreground="Gray" Width="28" DockPanel.Dock="Left" FontSize="11" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding CurrentFarm.Thresholds[1].Max}" Foreground="White" Width="32"
                                               DockPanel.Dock="Right" TextAlignment="Right" FontSize="11" VerticalAlignment="Center"/>
                                    <Slider Value="{Binding CurrentFarm.Thresholds[1].Max, Mode=TwoWay}"
                                            Minimum="0" Maximum="100" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                                </DockPanel>
                            </StackPanel>
                        </Border>

                        <!-- Temperature -->
                        <Border Grid.Row="0" Grid.Column="1" Background="#2D2D44" Margin="4" Padding="12" CornerRadius="4">
                            <StackPanel>
                                <TextBlock Text="🌡 온도" Foreground="#FF7043" FontWeight="Bold"/>
                                <TextBlock FontSize="28" FontWeight="Bold" Foreground="White"
                                           Text="{Binding CurrentSensorData.Temperature, StringFormat={}{0:F1}℃}"/>
                                <ProgressBar Value="{Binding CurrentSensorData.Temperature}" Maximum="50" Minimum="-10"
                                             Height="8" Margin="0,4" Foreground="#FF7043" Background="#444"/>
                                <DockPanel Margin="0,4,0,0">
                                    <TextBlock Text="최소" Foreground="Gray" Width="28" DockPanel.Dock="Left" FontSize="11" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding CurrentFarm.Thresholds[2].Min}" Foreground="White" Width="32"
                                               DockPanel.Dock="Right" TextAlignment="Right" FontSize="11" VerticalAlignment="Center"/>
                                    <Slider Value="{Binding CurrentFarm.Thresholds[2].Min, Mode=TwoWay}"
                                            Minimum="0" Maximum="40" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                                </DockPanel>
                                <DockPanel>
                                    <TextBlock Text="최대" Foreground="Gray" Width="28" DockPanel.Dock="Left" FontSize="11" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding CurrentFarm.Thresholds[2].Max}" Foreground="White" Width="32"
                                               DockPanel.Dock="Right" TextAlignment="Right" FontSize="11" VerticalAlignment="Center"/>
                                    <Slider Value="{Binding CurrentFarm.Thresholds[2].Max, Mode=TwoWay}"
                                            Minimum="0" Maximum="40" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                                </DockPanel>
                            </StackPanel>
                        </Border>

                        <!-- Light -->
                        <Border Grid.Row="1" Grid.Column="0" Background="#2D2D44" Margin="4" Padding="12" CornerRadius="4">
                            <StackPanel>
                                <TextBlock Text="☀ 채광" Foreground="#FFC107" FontWeight="Bold"/>
                                <TextBlock FontSize="28" FontWeight="Bold" Foreground="White"
                                           Text="{Binding CurrentSensorData.Light, StringFormat={}{0:F1}%}"/>
                                <ProgressBar Value="{Binding CurrentSensorData.Light}" Maximum="100" Minimum="0"
                                             Height="8" Margin="0,4" Foreground="#FFC107" Background="#444"/>
                                <DockPanel Margin="0,4,0,0">
                                    <TextBlock Text="최소" Foreground="Gray" Width="28" DockPanel.Dock="Left" FontSize="11" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding CurrentFarm.Thresholds[3].Min}" Foreground="White" Width="32"
                                               DockPanel.Dock="Right" TextAlignment="Right" FontSize="11" VerticalAlignment="Center"/>
                                    <Slider Value="{Binding CurrentFarm.Thresholds[3].Min, Mode=TwoWay}"
                                            Minimum="0" Maximum="100" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                                </DockPanel>
                                <DockPanel>
                                    <TextBlock Text="최대" Foreground="Gray" Width="28" DockPanel.Dock="Left" FontSize="11" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding CurrentFarm.Thresholds[3].Max}" Foreground="White" Width="32"
                                               DockPanel.Dock="Right" TextAlignment="Right" FontSize="11" VerticalAlignment="Center"/>
                                    <Slider Value="{Binding CurrentFarm.Thresholds[3].Max, Mode=TwoWay}"
                                            Minimum="0" Maximum="100" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                                </DockPanel>
                            </StackPanel>
                        </Border>

                        <!-- Soil Moisture -->
                        <Border Grid.Row="1" Grid.Column="1" Background="#2D2D44" Margin="4" Padding="12" CornerRadius="4">
                            <StackPanel>
                                <TextBlock Text="🌱 토양습도" Foreground="#26C6DA" FontWeight="Bold"/>
                                <TextBlock FontSize="28" FontWeight="Bold" Foreground="White"
                                           Text="{Binding CurrentSensorData.SoilMoisture, StringFormat={}{0:F1}%}"/>
                                <ProgressBar Value="{Binding CurrentSensorData.SoilMoisture}" Maximum="100" Minimum="0"
                                             Height="8" Margin="0,4" Foreground="#26C6DA" Background="#444"/>
                                <DockPanel Margin="0,4,0,0">
                                    <TextBlock Text="최소" Foreground="Gray" Width="28" DockPanel.Dock="Left" FontSize="11" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding CurrentFarm.Thresholds[4].Min}" Foreground="White" Width="32"
                                               DockPanel.Dock="Right" TextAlignment="Right" FontSize="11" VerticalAlignment="Center"/>
                                    <Slider Value="{Binding CurrentFarm.Thresholds[4].Min, Mode=TwoWay}"
                                            Minimum="0" Maximum="100" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                                </DockPanel>
                                <DockPanel>
                                    <TextBlock Text="최대" Foreground="Gray" Width="28" DockPanel.Dock="Left" FontSize="11" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding CurrentFarm.Thresholds[4].Max}" Foreground="White" Width="32"
                                               DockPanel.Dock="Right" TextAlignment="Right" FontSize="11" VerticalAlignment="Center"/>
                                    <Slider Value="{Binding CurrentFarm.Thresholds[4].Max, Mode=TwoWay}"
                                            Minimum="0" Maximum="100" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                                </DockPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </ScrollViewer>

            <!-- RIGHT PANEL -->
            <StackPanel Grid.Column="2" Background="#12121F">
                <!-- Farm Info -->
                <GroupBox Header="농장 정보" Style="{StaticResource GroupBoxStyle}">
                    <StackPanel>
                        <TextBlock Text="작물:" Foreground="Gray" FontSize="11"/>
                        <TextBlock Text="{Binding CurrentFarm.CropName}" Foreground="#4CAF50"
                                   FontSize="14" FontWeight="Bold" Margin="0,0,0,4"/>
                        <TextBlock Text="메모:" Foreground="Gray" FontSize="11"/>
                        <TextBox Text="{Binding CurrentFarm.Notes, UpdateSourceTrigger=PropertyChanged}"
                                 Background="#2D2D44" Foreground="White" BorderBrush="#444"
                                 Height="60" AcceptsReturn="True" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"/>
                        <Button Content="농장 관리" Command="{Binding OpenFarmManageCommand}"
                                Style="{StaticResource SidebarBtn}" Margin="0,6,0,0"/>
                    </StackPanel>
                </GroupBox>

                <!-- Lamp Control -->
                <GroupBox Header="램프 제어" Style="{StaticResource GroupBoxStyle}">
                    <UniformGrid Rows="2" Columns="2">
                        <ToggleButton Content="💡 램프1" IsChecked="{Binding Lamp1On, Mode=TwoWay}"
                                      Style="{StaticResource LampBtn}"/>
                        <ToggleButton Content="💡 램프2" IsChecked="{Binding Lamp2On, Mode=TwoWay}"
                                      Style="{StaticResource LampBtn}"/>
                        <ToggleButton Content="💡 램프3" IsChecked="{Binding Lamp3On, Mode=TwoWay}"
                                      Style="{StaticResource LampBtn}"/>
                        <ToggleButton Content="💡 램프4" IsChecked="{Binding Lamp4On, Mode=TwoWay}"
                                      Style="{StaticResource LampBtn}"/>
                    </UniformGrid>
                </GroupBox>

                <!-- Log Preview -->
                <GroupBox Header="최근 로그" Style="{StaticResource GroupBoxStyle}">
                    <ListBox ItemsSource="{Binding LogEntries}"
                             Background="#1A1A2E" Foreground="#888"
                             FontSize="10" Height="160"
                             VirtualizingStackPanel.IsVirtualizing="True"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="2,1"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </GroupBox>
            </StackPanel>
        </Grid>
    </DockPanel>
</Window>
