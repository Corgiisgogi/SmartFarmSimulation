<Window x:Class="SmartFarmUI.Views.LogView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="로그 뷰어" Height="560" Width="760"
        Background="#1E1E2E" Foreground="White"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#2D2D44"/><Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,4"/><Setter Property="Margin" Value="4,0"/><Setter Property="BorderBrush" Value="#555"/>
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="#1A1A2E"/><Setter Property="Foreground" Value="#CCC"/>
            <Setter Property="FontFamily" Value="Consolas"/><Setter Property="FontSize" Value="11"/>
            <Setter Property="BorderBrush" Value="#333"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="4,1"/>
        </Style>
    </Window.Resources>
    <DockPanel>
        <ToolBar DockPanel.Dock="Top" Background="#12121F">
            <Button Content="저장" Command="{Binding SaveLogsCommand}"/>
            <Button Content="불러오기" Command="{Binding LoadLogsCommand}"/>
            <Button Content="새로고침" Command="{Binding RefreshCommand}"/>
            <Separator/>
            <Button Content="초기화" Command="{Binding ClearLogsCommand}" Background="#B71C1C" BorderBrush="#E53935"/>
        </ToolBar>
        <StatusBar DockPanel.Dock="Bottom" Background="#12121F">
            <StatusBarItem><TextBlock Text="{Binding StatusMessage}" Foreground="#4CAF50"/></StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Foreground="Gray">
                    <Run Text="오류: "/><Run Text="{Binding ErrorCount}" Foreground="#F44336"/>
                    <Run Text="  경고: "/><Run Text="{Binding WarningCount}" Foreground="#FF9800"/>
                    <Run Text="  정보: "/><Run Text="{Binding InfoCount}" Foreground="#4CAF50"/>
                </TextBlock>
            </StatusBarItem>
        </StatusBar>
        <TabControl Background="#1E1E2E" BorderBrush="#333">
            <TabItem Header="전체">
                <ListBox ItemsSource="{Binding AllLogsView}" VirtualizingStackPanel.IsVirtualizing="True">
                    <ListBox.ItemTemplate><DataTemplate>
                        <TextBlock Text="{Binding}" TextWrapping="Wrap"/>
                    </DataTemplate></ListBox.ItemTemplate>
                </ListBox>
            </TabItem>
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="오류 "/><TextBlock Text="{Binding ErrorCount}" Foreground="#F44336" FontWeight="Bold"/>
                    </StackPanel>
                </TabItem.Header>
                <ListBox ItemsSource="{Binding ErrorLogsView}">
                    <ListBox.ItemTemplate><DataTemplate>
                        <TextBlock Text="{Binding}" TextWrapping="Wrap" Foreground="#F44336"/>
                    </DataTemplate></ListBox.ItemTemplate>
                </ListBox>
            </TabItem>
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="경고 "/><TextBlock Text="{Binding WarningCount}" Foreground="#FF9800" FontWeight="Bold"/>
                    </StackPanel>
                </TabItem.Header>
                <ListBox ItemsSource="{Binding WarningLogsView}">
                    <ListBox.ItemTemplate><DataTemplate>
                        <TextBlock Text="{Binding}" TextWrapping="Wrap" Foreground="#FF9800"/>
                    </DataTemplate></ListBox.ItemTemplate>
                </ListBox>
            </TabItem>
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="정보 "/><TextBlock Text="{Binding InfoCount}" Foreground="#4CAF50" FontWeight="Bold"/>
                    </StackPanel>
                </TabItem.Header>
                <ListBox ItemsSource="{Binding InfoLogsView}">
                    <ListBox.ItemTemplate><DataTemplate>
                        <TextBlock Text="{Binding}" TextWrapping="Wrap" Foreground="#4CAF50"/>
                    </DataTemplate></ListBox.ItemTemplate>
                </ListBox>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
