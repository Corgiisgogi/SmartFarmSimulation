<Window x:Class="SmartFarmUI.Views.AddCropView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="새 작물 추가" Height="510" Width="420"
        Background="#1E1E2E" Foreground="White"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#2D2D44"/><Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,5"/><Setter Property="Margin" Value="4"/><Setter Property="BorderBrush" Value="#555"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2D2D44"/><Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#555"/><Setter Property="Margin" Value="0,2"/><Setter Property="Padding" Value="4"/>
        </Style>
        <Style TargetType="Label"><Setter Property="Foreground" Value="#4CAF50"/></Style>
    </Window.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="새 작물 추가" FontSize="16" FontWeight="Bold" Foreground="#4CAF50" Margin="0,0,0,12"/>
            <StackPanel Grid.Row="1"><Label Content="작물 이름 *:"/>
                <TextBox Text="{Binding CropName, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
            <StackPanel Grid.Row="2"><Label Content="설명:"/>
                <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" Height="46" AcceptsReturn="True" TextWrapping="Wrap"/></StackPanel>
            <GroupBox Grid.Row="3" Header="습도 (%)" Foreground="#4CAF50" BorderBrush="#444" Margin="0,4">
                <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="4"><Label Content="최소:"/>
                        <TextBox Text="{Binding HumidityMin, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                    <StackPanel Grid.Column="1" Margin="4"><Label Content="최대:"/>
                        <TextBox Text="{Binding HumidityMax, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                </Grid>
            </GroupBox>
            <GroupBox Grid.Row="4" Header="온도 (℃)" Foreground="#4CAF50" BorderBrush="#444" Margin="0,4">
                <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="4"><Label Content="최소:"/>
                        <TextBox Text="{Binding TempMin, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                    <StackPanel Grid.Column="1" Margin="4"><Label Content="최대:"/>
                        <TextBox Text="{Binding TempMax, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                </Grid>
            </GroupBox>
            <GroupBox Grid.Row="5" Header="채광 (%)" Foreground="#4CAF50" BorderBrush="#444" Margin="0,4">
                <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="4"><Label Content="최소:"/>
                        <TextBox Text="{Binding LightMin, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                    <StackPanel Grid.Column="1" Margin="4"><Label Content="최대:"/>
                        <TextBox Text="{Binding LightMax, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                </Grid>
            </GroupBox>
            <GroupBox Grid.Row="6" Header="토양습도 (%)" Foreground="#4CAF50" BorderBrush="#444" Margin="0,4">
                <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="4"><Label Content="최소:"/>
                        <TextBox Text="{Binding SoilMin, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                    <StackPanel Grid.Column="1" Margin="4"><Label Content="최대:"/>
                        <TextBox Text="{Binding SoilMax, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                </Grid>
            </GroupBox>
            <TextBlock Grid.Row="7" Text="{Binding StatusMessage}" Foreground="Orange" Margin="0,4" TextWrapping="Wrap"/>
            <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                <Button Content="취소" Command="{Binding CancelCommand}"/>
                <Button Content="추가" Command="{Binding SubmitCommand}" Background="#4CAF50" BorderBrush="#66BB6A" IsDefault="True"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Window>
